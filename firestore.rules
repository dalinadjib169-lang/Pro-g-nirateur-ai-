rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is an admin
    // In this app, admins are primarily the developer email or a specific phone number.
    // However, they also get the role 'admin' stored in their user document.
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        request.auth.token.email == 'dalinadjib1990@gmail.com'
      );
    }
    
    // Function to check if the user account is active
    function isActiveUser() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    // Rules for 'users' collection
    match /users/{userId} {
      // Users can read their own data. Admins can read all users' data.
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Users can create their initial document upon registration
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own non-sensitive data, Admins can update anything
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))
        || isAdmin()
      );
      // Only admins can delete a user
      allow delete: if isAdmin();
    }

    // Rules for 'api_keys' collection
    match /api_keys/{keyId} {
      // Any authenticated user can read API keys to use the generator (or limit this based on your app's logic)
      allow read: if isAuthenticated();
      // Only admins can add, edit, or delete API keys
      allow write: if isAdmin();
    }

    // Rules for 'activation_codes' collection
    match /activation_codes/{codeId} {
      // Any authenticated user can read codes to activate them
      allow read: if isAuthenticated();
      // Any authenticated user can update a code (to mark it as used)
      allow update: if isAuthenticated();
      // Only admins can create or delete codes
      allow create, delete: if isAdmin();
    }
    
    // Rules for 'settings' collection
    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for 'messages' collection (Expert Chat)
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      // Only active users and admins can write messages
      allow create: if isActiveUser() || isAdmin();
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId);
    }
  }
}
